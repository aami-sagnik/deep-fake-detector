# Deep-Fake Detection System Configuration
# Copy this file to .env and fill in your values

# Google Generative AI API Key (for Gemma 4)
GOOGLE_API_KEY=your-api-key-here

# Model Settings
VISUAL_MODEL=google/vit-base-patch16-224
AUDIO_MODEL=facebook/wav2vec2-base-960h
DEVICE=cuda  # or 'cpu'

# Processing Settings
MAX_VIDEO_DURATION=600  # seconds
FRAME_SAMPLE_RATE=5     # sample every Nth frame
AUDIO_SAMPLE_RATE=16000 # Hz

# Detection Thresholds (0-1)
VISUAL_CONFIDENCE_THRESHOLD=0.5
AUDIO_CONFIDENCE_THRESHOLD=0.5
BIOMETRIC_CONFIDENCE_THRESHOLD=0.5
METADATA_CONFIDENCE_THRESHOLD=0.5

# Server Settings
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=
